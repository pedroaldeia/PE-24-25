# Parameters
n <- 20          # Sample dimension
mu0 <- 4         # Mean under H0
mu1 <- 5         # Mean under H1
alpha <- 0.1     # Significance level
m <- 900         # Number of samples
# Degrees of freedom for chi-squared distribution
df <- 2 * n
# Calculate the critical value for the test (quantile of chi-squared)
critical_value <- qchisq(1 - alpha, df = df)
# Simulate and estimate beta (empirical Type II error)
# Count how many times we fail to reject H0 when H1 is true
fail_to_reject_count <- 0
for (i in 1:m) {
# Generate a sample under H1 (true mean mu1)
# For exponential distribution, the rate parameter is 1/mu
sample_h1 <- rexp(n, rate = 1 / mu1)
# Calculate the sample mean
sample_mean <- mean(sample_h1)
# Calculate the test statistic T0 assuming H0 is true (using mu0)
t0_statistic <- (2 * n * sample_mean) / mu0
# Check if we fail to reject H0 (T0 <= critical_value)
if (t0_statistic <= critical_value) {
fail_to_reject_count <- fail_to_reject_count + 1
}
}
# Estimated beta
beta_hat <- fail_to_reject_count / m
# Calculate theoretical beta
# P(T* <= (mu0/mu1) * critical_value) where T* ~ chi-squared(df)
theoretical_beta <- pchisq((mu0 / mu1) * critical_value, df = df)
# Calculate the quotient
quotient <- beta_hat / theoretical_beta
# Round to 4 decimal places
result <- round(quotient, 4)
# Print the result
print(result)
